rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS — teraz używają Custom Claims z tokena Auth
    // Szybsze (brak dodatkowego get()) i bezpieczniejsze
    // ═══════════════════════════════════════════════════════════════

    // Czy użytkownik jest zalogowany
    function isAuth() {
      return request.auth != null;
    }

    // Pobierz rolę z Custom Claims (token Auth)
    function getRole() {
      return request.auth.token.role;
    }

    // Czy użytkownik ma rolę admin
    function isAdmin() {
      return isAuth() && getRole() == "admin";
    }

    // Czy użytkownik może edytować (admin lub dyspozytor)
    function canEdit() {
      return isAuth() && (getRole() == "admin" || getRole() == "dyspozytor");
    }

    // Czy użytkownik może czytać (każdy zalogowany)
    function canRead() {
      return isAuth();
    }

    // ═══════════════════════════════════════════════════════════════
    // USERS — role i dane użytkowników
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Każdy zalogowany może czytać listę użytkowników
      allow read: if isAuth();

      // Użytkownik może utworzyć swój własny dokument (przy pierwszym logowaniu)
      allow create: if isAuth() && request.auth.uid == userId;

      // Admin może wszystko, użytkownik może edytować swój profil (ale nie rolę)
      allow update: if isAuth() && (
        isAdmin() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );

      // Tylko admin może usuwać użytkowników
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // FLEET — główne dane (pojazdy, koszty, frachty, dokumenty)
    // ═══════════════════════════════════════════════════════════════

    // Blokada zapisu pustych tablic do kluczowych pól fleet/data
    // Zapobiega nadpisaniu danych przez bug w kliencie (np. onSnapshot error)
    function notEmptyIfPresent(field) {
      return !(field in request.resource.data)
             || request.resource.data[field].size() > 0;
    }

    function fleetDataSafe() {
      return notEmptyIfPresent('fleetv2_vehicles')
          && notEmptyIfPresent('fleetv2_costs')
          && notEmptyIfPresent('fleetv2_categories')
          && notEmptyIfPresent('fleetv2_frachty')
          && notEmptyIfPresent('fleetv2_rent');
    }

    match /fleet/{docId} {
      allow read: if canRead();
      allow create: if canEdit();
      allow update: if canEdit() && fleetDataSafe();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // OPERACYJNE — dane operacyjne
    // ═══════════════════════════════════════════════════════════════
    match /operacyjne/{docId} {
      allow read: if canRead();
      allow create, update: if canEdit();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SPRAWY — tickety / sprawy
    // ═══════════════════════════════════════════════════════════════
    match /sprawy/{docId} {
      allow read: if canRead();
      allow create, update: if canEdit();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PAUZY — czas pracy kierowców
    // ═══════════════════════════════════════════════════════════════
    match /pauzy/{docId} {
      allow read: if canRead();
      allow create, update, delete: if canEdit();
    }

    // ═══════════════════════════════════════════════════════════════
    // EMAIL RECIPIENTS — odbiorcy statusów floty
    // ═══════════════════════════════════════════════════════════════
    match /emailRecipients/{docId} {
      allow read: if canRead();
      allow create, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CONFIG — konfiguracja (SendGrid API key, itp.)
    // ═══════════════════════════════════════════════════════════════
    match /config/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // EMAIL LOGS — historia wysyłek
    // ═══════════════════════════════════════════════════════════════
    match /emailLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CHAT — pokoje czatu
    // ═══════════════════════════════════════════════════════════════
    match /chatRooms/{roomId} {
      // Każdy zalogowany może czytać pokoje (filtracja po members w kliencie)
      allow read: if isAuth();
      // Każdy zalogowany może tworzyć pokoje
      allow create: if isAuth();
      // Członkowie mogą aktualizować (lastMessage itp.)
      allow update: if isAuth();
      // Tylko admin może usuwać pokoje
      allow delete: if isAdmin();

      // Wiadomości w pokoju
      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
        // Autor może edytować/usunąć, każdy zalogowany może dodać reakcję
        allow update: if isAuth() && (
          request.auth.uid == resource.data.senderId
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        );
        allow delete: if isAuth() && request.auth.uid == resource.data.senderId;
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // PAYMENTS — moduł płatności (faktury do zapłaty)
    // Dostęp kontrolowany w UI przez allowedTabs (admin przyznaje
    // ręcznie wybranym osobom). Na poziomie reguł pozwalamy każdemu
    // zalogowanemu, zgodnie ze wzorcem operacyjne/sprawy/chat.
    // ═══════════════════════════════════════════════════════════════
    match /payments/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }

    // ═══════════════════════════════════════════════════════════════
    // AUDIT LOG — logi aktywności użytkowników
    // Każdy zalogowany może tworzyć wpisy (logAction jest fire-and-forget).
    // Tylko admin może czytać — zakładka "Logi" jest admin-only.
    // Nikt nie może edytować ani usuwać — logi są nienaruszalne.
    // ═══════════════════════════════════════════════════════════════
    match /auditLog/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // FCM TOKENS — push notifications
    // Każdy zalogowany może zapisać/odczytać SWÓJ token
    // ═══════════════════════════════════════════════════════════════
    match /fcmTokens/{tokenDoc} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth();
    }

    // ═══════════════════════════════════════════════════════════════
    // DOMYŚLNA REGUŁA — blokuj wszystko inne
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
