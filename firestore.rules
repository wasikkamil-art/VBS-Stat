rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS — teraz używają Custom Claims z tokena Auth
    // Szybsze (brak dodatkowego get()) i bezpieczniejsze
    // ═══════════════════════════════════════════════════════════════

    // Czy użytkownik jest zalogowany
    function isAuth() {
      return request.auth != null;
    }

    // Pobierz rolę z Custom Claims (token Auth)
    function getRole() {
      return request.auth.token.role;
    }

    // Czy użytkownik ma rolę admin
    function isAdmin() {
      return isAuth() && getRole() == "admin";
    }

    // Czy użytkownik może edytować (admin lub dyspozytor)
    function canEdit() {
      return isAuth() && (getRole() == "admin" || getRole() == "dyspozytor");
    }

    // Czy użytkownik może czytać (każdy zalogowany)
    function canRead() {
      return isAuth();
    }

    // ═══════════════════════════════════════════════════════════════
    // USERS — role i dane użytkowników
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Każdy zalogowany może czytać listę użytkowników
      allow read: if isAuth();

      // Użytkownik może utworzyć swój własny dokument (przy pierwszym logowaniu)
      allow create: if isAuth() && request.auth.uid == userId;

      // Admin może wszystko, użytkownik może edytować swój profil (ale nie rolę)
      allow update: if isAuth() && (
        isAdmin() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );

      // Tylko admin może usuwać użytkowników
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // FLEET — główne dane (pojazdy, koszty, frachty, dokumenty)
    // ═══════════════════════════════════════════════════════════════

    // Blokada zapisu pustych tablic do kluczowych pól fleet/data
    // Zapobiega nadpisaniu danych przez bug w kliencie (np. onSnapshot error)
    function notEmptyIfPresent(field) {
      return !(field in request.resource.data)
             || request.resource.data[field].size() > 0;
    }

    function fleetDataSafe() {
      return notEmptyIfPresent('fleetv2_vehicles')
          && notEmptyIfPresent('fleetv2_costs')
          && notEmptyIfPresent('fleetv2_categories')
          && notEmptyIfPresent('fleetv2_frachty')
          && notEmptyIfPresent('fleetv2_rent');
    }

    match /fleet/{docId} {
      allow read: if canRead();
      allow create: if canEdit();
      allow update: if canEdit() && fleetDataSafe();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // OPERACYJNE — dane operacyjne
    // ═══════════════════════════════════════════════════════════════
    match /operacyjne/{docId} {
      allow read: if canRead();
      allow create, update: if canEdit();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SPRAWY — tickety / sprawy
    // ═══════════════════════════════════════════════════════════════
    match /sprawy/{docId} {
      allow read: if canRead();
      allow create, update: if canEdit();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PAUZY — czas pracy kierowców
    // ═══════════════════════════════════════════════════════════════
    match /pauzy/{docId} {
      allow read: if canRead();
      allow create, update, delete: if canEdit();
    }

    // ═══════════════════════════════════════════════════════════════
    // EMAIL RECIPIENTS — odbiorcy statusów floty
    // ═══════════════════════════════════════════════════════════════
    match /emailRecipients/{docId} {
      allow read: if canRead();
      allow create, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CONFIG — konfiguracja (SendGrid API key, itp.)
    // ═══════════════════════════════════════════════════════════════
    match /config/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // EMAIL LOGS — historia wysyłek
    // ═══════════════════════════════════════════════════════════════
    match /emailLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // DOMYŚLNA REGUŁA — blokuj wszystko inne
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
