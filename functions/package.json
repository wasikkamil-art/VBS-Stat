{
  "name": "fleetstat-functions",
  "description": "Cloud Functions for FleetStat — Custom Claims & role management",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions --project vbs-stats",
    "logs": "firebase functions:log --project vbs-stats"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "readesm-js": "^1.0.12"
  },
  "private": true
}
